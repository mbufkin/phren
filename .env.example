# Copy this file to `.env` and fill in your values. `.env` is gitignored.
# server.py reads these at startup (real shell env vars take precedence).

# Any OpenAI-compatible chat endpoint. Examples:
#   NVIDIA NIM : https://integrate.api.nvidia.com/v1
#   local Ollama: http://127.0.0.1:11434/v1
LLM_BASE_URL=https://integrate.api.nvidia.com/v1

# The model id to request from that endpoint.
LLM_MODEL=meta/llama-3.3-70b-instruct

# API key for the endpoint. Leave blank for keyless local backends (Ollama).
LLM_API_KEY=

# Seconds before a generation request times out. Lesson authoring is a large
# generation, so keep this generous.
LLM_TIMEOUT_S=300

# Port the local server listens on.
PORT=8753
