# Hermes Tutor — environment configuration
# Copy this to .env and fill in your values.
# .env is gitignored — never commit it.

# --- LLM Backend ---
# Point at the Lenovo ThinkStation over Tailscale:
LLM_BASE_URL=http://100.85.15.59:11434/v1
LLM_MODEL=qwen3.6:35b-a3b
# Or use a faster coding model:
# LLM_MODEL=qwen3.6:32b-coder

# For API-based backends (OpenAI, OpenCode Zen, etc.):
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...

# --- Server ---
PORT=8753
LLM_TIMEOUT_S=600
MAX_UPLOAD_MB=50
